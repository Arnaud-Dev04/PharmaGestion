# ============================================================
# PharmaGestion — Configuration Environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# ── Base de données locale (SQLite — toujours actif) ────────
DB_URL_LOCAL=sqlite:///./pharmacy_local.db

# ── Base de données cloud (Render PostgreSQL) ───────────────
# Format : postgresql://user:password@host:port/dbname
# Obtenir depuis : Render Dashboard → Database → Internal URL
DB_URL_REMOTE=postgresql://pharma_user:MOT_DE_PASSE@dpg-xxxx.render.com:5432/pharma_db

# ── Sécurité JWT ────────────────────────────────────────────
SECRET_KEY=pharma_secret_key_arnaud_2026_xK9mP
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Application ─────────────────────────────────────────────
APP_NAME=PharmaGestion
APP_VERSION=2.0.0
ENVIRONMENT=production
DEBUG=False

# ── CORS (origines autorisées) ──────────────────────────────
# Mettre * en dev, ou l'URL Render en production
ALLOWED_ORIGINS=*
