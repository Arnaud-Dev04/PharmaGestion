{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    },
    {
      "src": "frontend_build/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/health", "dest": "api/index.py" },
    { "src": "/docs", "dest": "api/index.py" },
    { "src": "/redoc", "dest": "api/index.py" },
    { "src": "/openapi.json", "dest": "api/index.py" },
    { "src": "/auth/(.*)", "dest": "api/index.py" },
    { "src": "/stock/(.*)", "dest": "api/index.py" },
    { "src": "/pos/(.*)", "dest": "api/index.py" },
    { "src": "/sales/(.*)", "dest": "api/index.py" },
    { "src": "/pricing/(.*)", "dest": "api/index.py" },
    { "src": "/dashboard/(.*)", "dest": "api/index.py" },
    { "src": "/reports/(.*)", "dest": "api/index.py" },
    { "src": "/suppliers/(.*)", "dest": "api/index.py" },
    { "src": "/users/(.*)", "dest": "api/index.py" },
    { "src": "/settings/(.*)", "dest": "api/index.py" },
    { "src": "/admin/(.*)", "dest": "api/index.py" },
    { "src": "/customers/(.*)", "dest": "api/index.py" },
    { "src": "/license/(.*)", "dest": "api/index.py" },
    { "src": "/config/(.*)", "dest": "api/index.py" },
    { "src": "/metrics(.*)", "dest": "api/index.py" },
    { "src": "/(.*)", "dest": "frontend_build/$1" }
  ],
  "outputDirectory": "."
}
